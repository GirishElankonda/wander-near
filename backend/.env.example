# ─── Required ────────────────────────────────────────────────────────────────
# Your Stripe secret key (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example: https://wandernear.netlify.app,https://preview--wandernear.netlify.app
ALLOWED_ORIGINS=https://your-netlify-site.netlify.app

# ─── Stripe redirect URLs ─────────────────────────────────────────────────────
# The base URL of your frontend (used in Stripe success/cancel redirect URLs)
FRONTEND_URL=https://your-netlify-site.netlify.app

# ─── Server ───────────────────────────────────────────────────────────────────
# Render sets PORT automatically — only set this for local testing
# PORT=3000
