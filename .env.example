# =============================================================================
# WanderNear Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values. Never commit .env to git.
# For production, set these in your host's environment (e.g. Vercel, Netlify).
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase (client-side config – safe to expose in browser, but use env for
# multi-environment and to avoid committing project-specific values)
# -----------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Map & Geocoding (OpenStreetMap / Leaflet – no API keys required)
# These URLs are public; moving to env allows switching endpoints per environment.
# -----------------------------------------------------------------------------
VITE_OVERPASS_API_URL=https://overpass-api.de/api/interpreter
VITE_NOMINATIM_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
VITE_NOMINATIM_SEARCH_URL=https://nominatim.openstreetmap.org/search
VITE_OSM_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# -----------------------------------------------------------------------------
# Optional: Demo video (e.g. YouTube embed)
# -----------------------------------------------------------------------------
VITE_DEMO_VIDEO_EMBED_URL=https://www.youtube.com/embed/dQw4w9WgXcQ
